{
  "expo": {
    "name": "Dwiggy",
    "slug": "dwiggy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FF6B35"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dwiggy.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app uses location to show nearby restaurants and delivery options."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FF6B35"
      },
      "package": "com.dwiggy.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-font"
    ]
  }
}
